# MySQL async connection URL. Replace values with your local credentials.
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/news_app?charset=utf8mb4
SQL_ECHO=false

# Redis is used for news cache. The API remains usable if Redis is unavailable.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Set true only during local debugging; error responses can contain traceback details.
DEBUG_MODE=false
